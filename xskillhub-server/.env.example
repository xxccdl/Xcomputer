# XSkillHub 后端环境变量配置
# 复制此文件为 .env 并填写实际值，或通过 PM2/systemd 注入环境变量

# DeepSeek API Key（限免模式中继用，必填）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek API Base URL（默认官方地址，一般无需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 限免模式每日每 IP 调用额度（默认 50）
AI_DAILY_LIMIT=50

# 服务端口（默认 3210）
PORT=3210

# JWT 密钥（管理员认证用，生产环境务必使用强随机值）
# 生成方式：node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=请替换为强随机字符串

# 虎皮椒支付配置（付费购买积分功能）
XHPAY_APPID=你的虎皮椒Appid
XHPAY_APPSECRET=你的虎皮椒密钥
XHPAY_NOTIFY_URL_BASE=http://你的服务器地址:3210
XHPAY_RETURN_URL_BASE=https://你的域名
